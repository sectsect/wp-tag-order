{
  "name": "wp-tag-order",
  "version": "1.0.0",
  "main": "index.js",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "start": "",
    "type-check": "tsc",
    "type-check:watch": "npm run type-check -- --watch",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "lint:css": "biome format src/assets/css --write && stylelint 'src/**/*{,.*}.{css,scss}' --fix",
    "dev": "rspack build --env development --mode development --watch",
    "build": "rspack build --env production --mode production",
    "build:analyze": "RSDOCTOR=true rspack build --env production --mode production",
    "secretlint": "secretlint --maskSecrets --secretlintignore .gitignore '**/*'",
    "prepare": "husky"
  },
  "browserslist": "defaults and fully supports es6-module",
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "@commitlint/types": "^20.5.0",
    "@csstools/postcss-global-data": "^4.0.0",
    "@rsdoctor/rspack-plugin": "^1.5.9",
    "@rspack/cli": "^2.0.0",
    "@rspack/core": "^2.0.0",
    "@secretlint/secretlint-rule-preset-recommend": "^12.3.0",
    "@sect/webpack-sweet-entry": "^8.0.1",
    "@spotify/tsconfig": "^15.0.0",
    "@types/jquery": "^4.0.0",
    "@types/jqueryui": "^1.12.24",
    "@types/node": "^25.6.0",
    "css-loader": "^7.1.4",
    "fork-ts-checker-notifier-webpack-plugin": "^9.0.0",
    "fork-ts-checker-webpack-plugin": "^9.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.10",
    "postcss-calc": "^10.1.1",
    "postcss-combine-duplicated-selectors": "^10.0.3",
    "postcss-hexrgba": "^2.1.0",
    "postcss-import": "^16.1.1",
    "postcss-loader": "^8.2.1",
    "postcss-preset-env": "^11.2.1",
    "postcss-pxtorem": "^6.1.0",
    "postcss-reporter": "^7.1.0",
    "postcss-sort-media-queries": "^6.5.0",
    "secretlint": "^12.3.0",
    "stylelint": "^17.9.0",
    "stylelint-config-recess-order": "^7.7.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-webpack-plugin": "^5.1.0",
    "svg-spritemap-webpack-plugin": "^5.1.2",
    "ts-node": "^10.9.2",
    "tsc-files": "^1.1.4",
    "typescript": "^6.0.3",
    "webpack": "^5.106.2",
    "webpack-remove-empty-scripts": "^1.1.1"
  },
  "dependencies": {
    "core-js": "^3.49.0",
    "dotenv": "^17.4.2",
    "jquery": "^4.0.0",
    "sweetalert2": "^11.26.24"
  }
}
